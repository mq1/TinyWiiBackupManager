import { Card } from "card.slint";
import { TooltipArea } from "tooltip-area.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { Logic } from "../logic.slint";

export component ViewAs inherits Card {
    pure function get-bg(view-as: int, hovered: bool) -> color {
        if Logic.config.view-as == view-as {
            MyPalette.selection-background
        } else if hovered {
            MyPalette.alternate-background
        } else {
            transparent
        }
    }

    height: 38px;
    clip: true;
    border-radius: 10px;

    HorizontalLayout {
        TooltipArea {
            width: 25px;
            height: 38px;

            tooltip: "View as grid";
            background: get-bg(0, self.has-hover);
            clicked => Logic.set-view-as(0);

            IconDisplay {
                icon: IconSet.LayoutGrid;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        TooltipArea {
            width: 25px;
            height: 38px;

            tooltip: "View as table";
            background: get-bg(1, self.has-hover);
            clicked => Logic.set-view-as(1);

            IconDisplay {
                icon: IconSet.Table;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }
    }
}
