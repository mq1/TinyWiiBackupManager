export enum Page {
    Games,
    Settings,
    About,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum SortBy { 
    NameAscending,
    NameDescending,
    SizeAscending,
    SizeDescending,
    None,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum ViewAs {
  Grid,
  Table,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum TxtCodesSource {
    WebArchive,
    GameHacking,
    Rc24,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum ThemePreference {
    System,
    Light,
    Dark,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(default, rename_all = "snake_case"))
export struct ConfigContents {
    always_split: bool,
    mount_point: string,
    remove_sources_apps: bool,
    remove_sources_games: bool,
    scrub_update_partition: bool,
    sort_by: SortBy,
    view_as: ViewAs,
    wii_ip: string,
    txt_codes_source: TxtCodesSource,
    theme_preference: ThemePreference,
    wii_output_format: string,
    gc_output_format: string,
    known_drives: [string],
}

export struct Config {
    path: string,
    contents: ConfigContents,
}

export enum IconButtonKind {
    Primary,
    Secondary,
    Warning,
    Danger,
}

export struct Message {
    text: string,
    button: IconButtonKind,
}
