import { GamesToolbar } from "components/games-toolbar.slint";
import { ScrollView } from "std-widgets.slint";
import { State } from "state.slint";
import { HorizontalLine } from "components/horizontal-line.slint";
import { IconSet, IconDisplay } from "@lucide";
import { Card } from "components/card.slint";
import { MyPalette } from "styling.slint";
import { GameRow } from "components/game-row.slint";

export component GameTablePage inherits Rectangle {
    toolbar := GamesToolbar {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
    }

    Card {
        x: 10px;
        y: toolbar.height + 20px;
        height: parent.height - toolbar.height - 30px;
        width: parent.width - 20px;
        clip: true;

        ScrollView {
            x: 0px;
            y: 0px;
            height: parent.height;
            viewport-height: v.preferred-height;

            v := VerticalLayout {
                for game in State.game-list.games: VerticalLayout {
                    spacing: 5px;

                    if (game.is-wii && State.config.contents.show-wii) || (!game.is-wii && State.config.contents.show-gc): VerticalLayout {
                        GameRow {
                            game: game;
                        }

                        HorizontalLine {
                            background: MyPalette.border.mix(MyPalette.foreground, 0.8);
                        }
                    }
                }
            }
        }
    }
}
