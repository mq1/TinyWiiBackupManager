import { Palette } from "std-widgets.slint";
import { Navbar } from "components/navbar.slint";
import { GameGridPage } from "game-grid-page.slint";
import { SettingsPage } from "settings-page.slint";
import { AboutPage } from "about-page.slint";
import {
    Page,
    ViewAs,
    DisplayedGame,
    HomebrewApp,
    OscApp,
    Notification,
    Config,
    QueuedConversion,
    DriveInfo,
    ThemePreference,
} from "types.slint";
import { MyPalette } from "styling.slint";
import { Logic } from "logic.slint";
import { VerticalLine } from "components/vertical-line.slint";
import { Card } from "components/card.slint";
import { GameTablePage } from "game-table-page.slint";
import { Notifications } from "components/notifications.slint";
import { GameInfoModal } from "components/game-info-modal.slint";
import { HomebrewAppsGridPage } from "homebrew-apps-grid-page.slint";
import { HomebrewAppInfoModal } from "components/homebrew-app-info-modal.slint";
import { HomebrewAppsTablePage } from "homebrew-apps-table-page.slint";
import { OscGridPage } from "osc-grid-page.slint";
import { OscTablePage } from "osc-table-page.slint";
import { OscAppInfoModal } from "components/osc-app-info-modal.slint";
import { ConfirmationModal } from "components/confirmation-modal.slint";
import { Tooltip } from "tooltip.slint";

export * from "types.slint";
export { Logic }

export component AppWindow inherits Window {
    min-width: 800px;
    min-height: 600px;
    background: MyPalette.background;
    title: Logic.drive-info.label.is-empty ? "TinyWiiBackupManager  ›  No drive selected" : "TinyWiiBackupManager  ›  \{Logic.drive-info.label}  (\{Logic.drive-info.used-gib.to-fixed(2)}/\{Logic.drive-info.total-gib.to-fixed(2)} GiB)";
    default-font-size: 14px;

    private property <Page> current-page: Page.Games;
    private property <int> current-game-i: -1;
    private property <int> current-homebrew-app-i: -1;
    private property <int> current-osc-app-i: -1;
    private property <int> game-to-scrub: -1;
    private property <int> game-to-delete: -1;
    private property <int> homebrew-app-to-delete: -1;

    // Initialize
    Timer {
        interval: 1ms;
        running: true;
        triggered => {
            if Logic.config.contents.theme-preference == ThemePreference.Light {
                Palette.color-scheme = ColorScheme.light;
            } else if Logic.config.contents.theme-preference == ThemePreference.Dark {
                Palette.color-scheme = ColorScheme.dark;
            }
            Logic.set-window-color(Palette.color-scheme == ColorScheme.dark);
            Logic.refresh-all();
            Logic.cache-osc-contents(false);
            self.running = false;
        }
    }

    HorizontalLayout {
        Navbar {
            current-page <=> current-page;
        }

        VerticalLayout {
            Rectangle {
                background: MyPalette.alternate-background;
                border-top-left-radius: 10px;
                border-width: 1px;
                border-color: MyPalette.border;

                if current-page == Page.Games && Logic.config.contents.view-as == ViewAs.Grid: GameGridPage {
                    open-info(i) => {
                        current-game-i = i;
                        Logic.load-game-info(i);
                    }
                }
                if current-page == Page.Games && Logic.config.contents.view-as == ViewAs.Table: GameTablePage {
                    open-info(i) => {
                        current-game-i = i;
                        Logic.load-game-info(i);
                    }
                }
                if current-page == Page.HomebrewApps && Logic.config.contents.view-as == ViewAs.Grid: HomebrewAppsGridPage {
                    open-info(i) => {
                        current-homebrew-app-i = i;
                    }
                }
                if current-page == Page.HomebrewApps && Logic.config.contents.view-as == ViewAs.Table: HomebrewAppsTablePage {
                    open-info(i) => {
                        current-homebrew-app-i = i;
                    }
                }
                if current-page == Page.Osc && Logic.config.contents.view-as == ViewAs.Grid: OscGridPage {
                    open-info(i) => {
                        current-osc-app-i = i;
                    }
                }
                if current-page == Page.Osc && Logic.config.contents.view-as == ViewAs.Table: OscTablePage {
                    open-info(i) => {
                        current-osc-app-i = i;
                    }
                }
                if current-page == Page.Settings: SettingsPage { }
                if current-page == Page.About: AboutPage { }
            }

            if !Logic.status.is-empty: HorizontalLayout {
                VerticalLine { }

                HorizontalLayout {
                    padding: 10px;

                    Text {
                        text: Logic.status;
                    }
                }
            }
        }
    }

    if game-to-delete >= 0: ConfirmationModal {
        message: "Are you sure you want to delete \{Logic.games[game-to-delete].title}? This action cannot be undone.";

        cancelled => {
            game-to-delete = -1;
        }
        confirmed => {
            Logic.delete-game(Logic.games[game-to-delete]);
            game-to-delete = -1;
        }
    }

    if homebrew-app-to-delete >= 0: ConfirmationModal {
        message: "Are you sure you want to delete \{Logic.homebrew-apps[homebrew-app-to-delete].meta.name}? This action cannot be undone.";

        cancelled => {
            homebrew-app-to-delete = -1;
        }
        confirmed => {
            Logic.delete-homebrew-app(Logic.homebrew-apps[homebrew-app-to-delete]);
            homebrew-app-to-delete = -1;
        }
    }

    if game-to-scrub >= 0: ConfirmationModal {
        message: "Are you sure you want to scrub \{Logic.games[game-to-scrub].title}? This action cannot be undone.";

        cancelled => {
            game-to-scrub = -1;
        }
        confirmed => {
            Logic.scrub-game(Logic.games[game-to-scrub]);
            game-to-scrub = -1;
        }
    }

    if Logic.conversion-queue-buffer.length > 0: ConfirmationModal {
        message: "Are you sure you want to add \{Logic.conversion-queue-buffer.length} conversions to the queue?";

        cancelled => Logic.clear-conversion-queue-buffer();
        confirmed => Logic.confirm-conversion-queue-buffer();
    }

    if current-game-i >= 0: GameInfoModal {
        game: Logic.games[current-game-i];
        closed => {
            current-game-i = -1;
            Logic.set-crc32-status("");
        }
    }

    if current-homebrew-app-i >= 0: HomebrewAppInfoModal {
        app: Logic.homebrew-apps[current-homebrew-app-i];
        closed => {
            current-homebrew-app-i = -1;
        }
    }

    if current-osc-app-i >= 0: OscAppInfoModal {
        app: Logic.osc-apps[current-osc-app-i];
        closed => {
            current-osc-app-i = -1;
        }
    }

    if Logic.notifications.length > 0: Notifications {
        x: root.width - self.width;
        y: root.height - self.height;
    }

    if !Tooltip.text.is-empty: Card {
        x: Tooltip.mouse-x + t.preferred-width + 18px > root.width ? Tooltip.mouse-x - t.preferred-width - 18px : Tooltip.mouse-x;
        y: Tooltip.mouse-y;

        width: t.preferred-width + 18px;
        height: t.preferred-height + 16px;

        HorizontalLayout {
            padding-top: 8px;
            padding-bottom: 8px;
            padding-left: 9px;
            padding-right: 9px;

            t := Text {
                text: Tooltip.text;
            }
        }
    }
}
