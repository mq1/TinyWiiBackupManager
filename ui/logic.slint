import {
    Config,
    DriveInfo,
    Game,
    HomebrewApp,
    OscApp,
    Notification,
    QueuedConversion,
    WiiOutputFormat,
    GcOutputFormat,
    TxtCodesSource,
    ThemePreference,
    ViewAs,
    SortBy,
} from "types.slint";

export global Logic {
    in-out property <Config> config;
    in-out property <string> app-version;
    in-out property <string> data-dir;
    in-out property <DriveInfo> drive-info;
    in-out property <[Game]> games;
    in-out property <[HomebrewApp]> homebrew-apps;
    in-out property <[OscApp]> osc-apps;
    in-out property <[Notification]> notifications;
    in-out property <[QueuedConversion]> conversion-queue;
    in-out property <[QueuedConversion]> conversion-queue-buffer;
    in-out property <string> status;
    in-out property <string> crc32-status;
    in-out property <int> osc-refreshed-x-hours-ago;
    in-out property <int> osc-refreshed-x-minutes-ago;

    callback filter-games(string);
    callback filter-homebrew-apps(string);
    callback filter-osc-apps(string);
    callback cache-osc-contents(bool);
    callback refresh-all();
    callback confirm-conversion-queue-buffer();
    callback clear-conversion-queue-buffer();
    callback archive-game(Game);
    callback scrub-game(Game);
    callback delete-game(Game);
    callback delete-homebrew-app(HomebrewApp);
    callback pick-games(bool);
    callback open-that(string);
    callback close-notification(int);
    callback pick-homebrew-apps();
    callback checksum(Game);
    callback set-window-color(bool);
    callback pair-homebrew-osc();
    callback install-osc-app(OscApp);
    callback download-osc-icons();
    callback load-game-info(int);

    // config
    callback pick-mount-point();
    callback set-wii-output-format(WiiOutputFormat);
    callback set-gc-output-format(GcOutputFormat);
    callback set-always-split(bool);
    callback set-scrub-update-partition(bool);
    callback set-remove-sources-games(bool);
    callback set-remove-sources-apps(bool);
    callback set-txt-codes-source(TxtCodesSource);
    callback set-theme-preference(ThemePreference);
    callback set-view-as(ViewAs);
    callback set-sort-by(SortBy);
    callback set-show-wii(bool);
    callback set-show-gc(bool);

    // util
    callback sync-config();
    callback notify-error(string);
    callback notify-info(string);
    callback trigger-conversion();
    callback set-status(string);
    callback set-crc32-status(string);
    callback reload-osc-icon(int);
    callback reload-cover(int);
    callback finished-downloading-covers();
    callback osc-contents-cached();
}
