import { GamesToolbar } from "components/games-toolbar.slint";
import { ScrollView } from "std-widgets.slint";
import { State } from "state.slint";
import { HorizontalLine } from "components/horizontal-line.slint";
import { IconSet, IconDisplay } from "@lucide";
import { Card } from "components/card.slint";
import { MyPalette } from "styling.slint";
import { GameRow } from "components/game-row.slint";
import { GamesOtherToolbar } from "components/games-other-toolbar.slint";

export component GameTablePage inherits VerticalLayout {
    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        GamesToolbar { }

        GamesOtherToolbar { }
    }

    ScrollView {
        width: parent.width;
        viewport-height: v.preferred-height;

        v := VerticalLayout {
            padding: 10px;
            padding-top: 0px;

            Card {
                clip: true;
                height: v2.preferred-height;

                v2 := VerticalLayout {
                    if State.game-list.filter.is-empty: VerticalLayout {
                        for game in State.game-list.games: HorizontalLayout {
                            if (game.is-wii && State.config.contents.show-wii) || (!game.is-wii && State.config.contents.show-gc): VerticalLayout {
                                GameRow {
                                    game: game;
                                }

                                HorizontalLine { }
                            }
                        }
                    }

                    if !State.game-list.filter.is-empty: VerticalLayout {
                        for game in State.game-list.filtered-games: VerticalLayout {
                            GameRow {
                                game: game;
                            }

                            HorizontalLine { }
                        }
                    }
                }
            }
        }
    }
}
