import { ScrollView } from "std-widgets.slint";
import { IconSet, IconDisplay } from "@lucide";
import { State } from "state.slint";
import { SettingCard } from "components/setting-card.slint";
import { MyPalette } from "styling.slint";
import {
    WiiOutputFormat,
    GcOutputFormat,
    TxtCodesSource,
    ThemePreference,
} from "types.slint";

export component SettingsPage inherits Rectangle {
    HorizontalLayout {
        x: 10px;
        y: 20px;
        spacing: 5px;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Settings";
            font-size: 18px;
        }
    }

    ScrollView {
        x: 0px;
        y: 38px + 20px;
        height: root.height - 38px - 20px;

        VerticalLayout {
            width: 100%;
            padding-left: 10px;
            padding-right: 15px;
            padding-bottom: 10px;
            spacing: 10px;

            SettingCard {
                icon: IconSet.Disc3;
                label: "Wii output format";
                items: ["WBFS (recommended)", "ISO (very large)"];
                active-item: State.config.contents.wii-output-format == WiiOutputFormat.Wbfs ? 0 : 1;

                selected(i) => {
                    if i == 0 {
                        State.config.contents.wii-output-format = WiiOutputFormat.Wbfs;
                    } else {
                        State.config.contents.wii-output-format = WiiOutputFormat.Iso;
                    }

                    State.write-config();
                }
            }

            SettingCard {
                icon: IconSet.Disc3;
                label: "GameCube output format";
                items: [
                    "ISO (recommended)",
                    "CISO (much smaller, slightly slower, less metadata in game loaders)"
                ];
                active-item: State.config.contents.gc-output-format == GcOutputFormat.Iso ? 0 : 1;

                selected(i) => {
                    if i == 0 {
                        State.config.contents.gc-output-format = GcOutputFormat.Iso;
                    } else {
                        State.config.contents.gc-output-format = GcOutputFormat.Ciso;
                    }

                    State.write-config();
                }
            }

            SettingCard {
                icon: IconSet.SquareSplitHorizontal;
                label: "Split output";
                items: ["Only when needed (recommended)", "Always 4GB-32KB"];
                active-item: State.config.contents.always-split ? 1 : 0;

                selected(i) => {
                    State.config.contents.always-split = i == 1;
                    State.write-config();
                }
            }

            SettingCard {
                icon: IconSet.FileMinusCorner;
                label: "Remove update partition on WBFS/CISO";
                items: [
                    "No (recommended)",
                    "Yes (saves some space; update partition is zeroed, but still there)"
                ];
                active-item: State.config.contents.scrub-update-partition ? 1 : 0;

                selected(i) => {
                    State.config.contents.scrub-update-partition = i == 1;
                    State.write-config();
                }
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding games";
                items: ["No (recommended)", "Yes"];
                active-item: State.config.contents.remove-sources-games ? 1 : 0;

                selected(i) => {
                    State.config.contents.remove-sources-games = i == 1;
                    State.write-config();
                }
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding apps";
                items: ["No (recommended)", "Yes"];
                active-item: State.config.contents.remove-sources-apps ? 1 : 0;
            }

            SettingCard {
                pure function get-active-item() -> int {
                    if State.config.contents.txt-codes-source == TxtCodesSource.WebArchive {
                        0
                    } else if State.config.contents.txt-codes-source == TxtCodesSource.GameHacking {
                        1
                    } else {
                        2
                    }
                }

                icon: IconSet.Skull;
                label: "Cheat codes source";
                items: [
                    "geckocodes.org-201909 archive (recommended)",
                    "gamehacking.org (up to date)",
                    "codes.rc24.xyz",
                ];
                active-item: get-active-item();

                selected(i) => {
                    if i == 0 {
                        State.config.contents.txt-codes-source = TxtCodesSource.WebArchive;
                    } else if i == 1 {
                        State.config.contents.txt-codes-source = TxtCodesSource.GameHacking;
                    } else {
                        State.config.contents.txt-codes-source = TxtCodesSource.Rc24;
                    }

                    State.write-config();
                }
            }

            SettingCard {
                pure function get-active-item() -> int {
                    if State.config.contents.theme-preference == ThemePreference.System {
                        0
                    } else if State.config.contents.theme-preference == ThemePreference.Light {
                        1
                    } else {
                        2
                    }
                }

                icon: IconSet.SunMoon;
                label: "Theme";
                items: ["System (requires restart)", "Light", "Dark"];
                active-item: get-active-item();

                selected(i) => {
                    if i == 0 {
                        State.config.contents.theme-preference = ThemePreference.System;
                    } else if i == 1 {
                        State.config.contents.theme-preference = ThemePreference.Light;
                    } else {
                        State.config.contents.theme-preference = ThemePreference.Dark;
                    }

                    State.apply-theme();
                    State.write-config();
                }
            }
        }
    }
}
