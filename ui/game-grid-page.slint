import { ScrollView } from "std-widgets.slint";
import { State } from "state.slint";
import { MyPalette } from "styling.slint";
import { GameCard } from "components/game-card.slint";
import { IconSet, IconDisplay } from "@lucide";
import { GamesToolbar } from "components/games-toolbar.slint";
import { GameFilter } from "components/game-filter.slint";

export component GameGridPage inherits Rectangle {
    toolbar := GamesToolbar {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
    }

    ScrollView {
        y: toolbar.height + 15px;
        height: parent.height - toolbar.height - 15px;
        width: parent.width;

        VerticalLayout {
            x: 5px;
            alignment: start;
            width: parent.width - 10px;

            HorizontalLayout {
                alignment: space-between;
                padding: 5px;

                GameFilter { }

                HorizontalLayout {
                    Text {
                        vertical-alignment: center;
                        text: "\{State.game-list.games.length} game\{State.game-list.games.length == 1 ? "" : "s"}   ~ \{State.game-list.total-size.to-fixed(2)} GiB";
                    }
                }
            }

            if State.game-list.filter.is-empty: FlexboxLayout {
                width: parent.width;
                align-content: start;

                for game in State.game-list.games: HorizontalLayout {
                    padding: (game.is-wii && State.config.contents.show-wii) || (!game.is-wii && State.config.contents.show-gc) ? 5px : 0px;

                    if (game.is-wii && State.config.contents.show-wii) || (!game.is-wii && State.config.contents.show-gc): GameCard {
                        game: game;
                    }
                }
            }

            if !State.game-list.filter.is-empty: FlexboxLayout {
                padding: 5px;
                width: parent.width;
                spacing: 10px;
                align-content: start;

                for game in State.game-list.filtered-games: GameCard {
                    game: game;
                }
            }
        }
    }
}
