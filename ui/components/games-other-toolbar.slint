import { GameFilter } from "game-filter.slint";
import { Logic } from "../logic.slint";

export component GamesOtherToolbar inherits HorizontalLayout {
    alignment: space-between;
    height: 38px;
    padding-right: 20px;

    GameFilter { }

    Text {
        height: parent.height;
        vertical-alignment: center;
        horizontal-alignment: end;
        text: "\{Logic.games.length} game\{Logic.games.length == 1 ? "" : "s"}   ~ \{Logic.drive-info.games-gib.to-fixed(2)} GiB";
    }
}
