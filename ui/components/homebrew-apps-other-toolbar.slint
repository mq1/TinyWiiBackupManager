import { MyPalette } from "../styling.slint";
import { HomebrewAppsFilter } from "homebrew-apps-filter.slint";
import { HomebrewApp } from "../types.slint";

export component HomebrewAppsOtherToolbar inherits HorizontalLayout {
    in property <[HomebrewApp]> apps;
    in property <float> total-size-mib: 0; // TODO

    alignment: space-between;
    height: 38px;
    padding-right: 10px;

    HomebrewAppsFilter { }

    Text {
        height: parent.height;
        vertical-alignment: center;
        horizontal-alignment: end;
        text: "\{apps.length} app\{apps.length == 1 ? "" : "s"}   ~ \{total-size-mib.to-fixed(2)} MiB";
    }
}
