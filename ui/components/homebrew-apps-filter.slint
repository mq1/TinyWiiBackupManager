import { Card } from "card.slint";
import { LineEdit } from "std-widgets.slint";
import { MyPalette } from "../styling.slint";
import { IconSet, IconDisplay } from "@lucide";
import { State } from "../state.slint";
import { MyLineEdit } from "my-line-edit.slint";

export component HomebrewAppsFilter inherits Card {
    width: 210px;
    height: 38px;

    HorizontalLayout {
        spacing: 10px;

        VerticalLayout {
            padding-left: 15px;
            alignment: center;

            IconDisplay {
                icon: IconSet.Search;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        VerticalLayout {
            alignment: center;

            MyLineEdit {
                text <=> State.homebrew-apps-filter;
                placeholder-text: "Search by Name/Author";
                changed text => State.filter-homebrew-apps();
            }
        }
    }
}
