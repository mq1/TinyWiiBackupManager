import { Card } from "card.slint";
import { DisplayedOscApp } from "../types.slint";
import { IconButton } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";

export component OscAppCard inherits Card {
    in property <DisplayedOscApp> app;

    callback open-info();
    callback install();

    width: 172px;
    height: self.min-height;

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        HorizontalLayout {
            alignment: space-between;

            HorizontalLayout {
                spacing: 5px;

                IconDisplay {
                    icon: IconSet.Tag;
                    size: 13px;
                    stroke: MyPalette.foreground;
                }

                Text {
                    text: app.version;
                    wrap: no-wrap;
                    overflow: elide;
                }
            }

            Text {
                text: "\{app.uncompressed-size-mib.to-fixed(2)} MiB";
                wrap: no-wrap;
                horizontal-alignment: right;
            }
        }

        Image {
            source: app.icon;
            height: 48px;
        }

        Text {
            text: app.name;
            horizontal-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        HorizontalLayout {
            spacing: 5px;

            IconButton {
                label: "Info";
                icon: IconSet.Info;
                clicked => open-info();
            }

            IconButton {
                icon: IconSet.HardDriveDownload;
                tooltip: "Install";
                clicked => install();
            }

            IconButton {
                icon: IconSet.MonitorUp;
                tooltip: "Wiiload";
            }
        }
    }
}
