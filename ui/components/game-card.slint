import { Card } from "card.slint";
import { Game } from "../types.slint";
import { VerticalBox } from "std-widgets.slint";
import { IconButton } from "icon-button.slint";
import { IconSet } from "@lucide";

export global GameCardConsts {
    out property <length> width: 165px;
    out property <length> spaced-width: width + 10px;
    out property <length> height: 205px;
    out property <length> spaced-height: height + 10px;
}

export component GameCard inherits Card {
    in property <Game> game;

    width: GameCardConsts.width;
    height: GameCardConsts.height;

    VerticalBox {
        HorizontalLayout {
            Text {
                text: game.id;
                wrap: no-wrap;
            }

            Text {
                text: game.size-gib + " GiB";
                wrap: no-wrap;
                horizontal-alignment: right;
            }
        }

        Image {
            source: game.cover;
            height: 93px;
        }

        Text {
            text: game.title;
            horizontal-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        HorizontalLayout {
            spacing: 5px;

            IconButton {
                label: "Info";
                icon: IconSet.Info;
                hint: "shows \"" + game.title + "\" disc info + gametdb metadata";
            }

            IconButton {
                icon: IconSet.HardDriveDownload;
                hint: "archives \"" + game.title + "\" to PC";
            }

            IconButton {
                icon: IconSet.Trash;
                hint: "deletes \"" + game.title + "\", freeing " + game.size-gib + " GiB";
            }
        }
    }
}
