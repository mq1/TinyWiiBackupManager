import {
    Config,
    GameList,
    EmptyResult,
    Game,
    DiscInfoResult,
    DriveInfo,
    QueuedConversion,
    ConfigContents,
    Notification,
    SortBy,
} from "types.slint";

export global Rust {
    pure callback open(string) -> EmptyResult;
    pure callback pick-mount-point() -> string;
    pure callback get-drive-info(string) -> DriveInfo;
    pure callback write-config(Config) -> EmptyResult;
    pure callback delete-dir(string) -> EmptyResult;
    pure callback get-game-list(string, SortBy) -> GameList;
    pure callback filter-games([Game], string) -> [Game];
    pure callback get-disc-info(string) -> DiscInfoResult;
    pure callback pick-games(GameList, ConfigContents, DriveInfo) -> [QueuedConversion];
    pure callback sort-games([Game], SortBy) -> [Game];
    pure callback add-notification([Notification], Notification);
    pure callback close-notification([Notification], int);
}
