import { Card } from "card.slint";
import { CheckBox } from "std-widgets.slint";
import { TooltipArea } from "tooltip-area.slint";
import { VerticalLine } from "vertical-line.slint";
import { IconDisplay, IconSet } from "@lucide";
import { MyPalette } from "../styling.slint";
import { Rust } from "../rust.slint";
import { Config } from "../types.slint";

export component ShowWiiGc inherits Card {
    in property <Config> config;

    height: 38px;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 5px;

        CheckBox {
            checked: config.contents.show-wii;
            toggled => Rust.set-show-wii(self.checked);
        }

        TooltipArea {
            tooltip: "Show Wii";
            width: wii.preferred-width;

            wii := Text {
                height: 38px;
                vertical-alignment: center;
                text: "Wii";
            }
        }

        VerticalLine { }

        CheckBox {
            checked: config.contents.show-gc;
            toggled => Rust.set-show-gc(self.checked);
        }

        TooltipArea {
            tooltip: "Show GameCube";
            width: gc.preferred-width;

            gc := Text {
                height: 38px;
                vertical-alignment: center;
                text: "GC";
            }
        }
    }
}
