import { IconButton, IconButtonKind } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { ViewAs } from "view-as.slint";
import { SortGamesAndHomebrewApps } from "sort-games-and-homebrew-apps.slint";
import { MyPalette } from "../styling.slint";
import { Rust } from "../rust.slint";
import { Config } from "../types.slint";

export component HomebrewAppsToolbar inherits HorizontalLayout {
    in property <Config> config;

    alignment: space-between;
    height: 38px;

    HorizontalLayout {
        padding-top: 10px;
        spacing: 5px;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Homebrew apps";
            font-size: 18px;
        }
    }

    HorizontalLayout {
        spacing: 10px;

        SortGamesAndHomebrewApps {
            config: config;
        }

        ViewAs {
            config: config;
        }

        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                spacing: 10px;

                IconButton {
                    icon: IconSet.RotateCw;
                    tooltip: "Refresh games and apps";
                    rounded: true;
                    kind: IconButtonKind.Primary;
                    font-size: 18px;
                    width: 34px;
                    height: 34px;
                    clicked => Rust.refresh-all();
                }

                IconButton {
                    icon: IconSet.Plus;
                    tooltip: "Add new apps";
                    rounded: true;
                    kind: IconButtonKind.Primary;
                    font-size: 18px;
                    width: 34px;
                    height: 34px;
                    clicked => Rust.pick-homebrew-apps();
                }
            }
        }
    }
}
