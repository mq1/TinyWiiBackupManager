import { Card } from "card.slint";
import { TooltipArea } from "tooltip-area.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { State } from "../state.slint";
import { ViewAs } from "../types.slint";

export component ViewAs inherits Card {
    pure function get-bg(view-as: ViewAs, hovered: bool) -> color {
        if State.config.contents.view-as == view-as {
            MyPalette.selection-background
        } else if hovered {
            MyPalette.alternate-background
        } else {
            transparent
        }
    }

    height: 38px;
    clip: true;
    border-radius: 10px;

    HorizontalLayout {
        TooltipArea {
            width: 25px;
            height: 38px;

            tooltip: "View as grid";
            background: get-bg(ViewAs.Grid, self.has-hover);
            clicked => {
                State.config.contents.view-as = ViewAs.Grid;
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.LayoutGrid;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        TooltipArea {
            width: 25px;
            height: 38px;

            tooltip: "View as table";
            background: get-bg(ViewAs.Table, self.has-hover);
            clicked => {
                State.config.contents.view-as = ViewAs.Table;
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.Table;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }
    }
}
