export enum Page {
    Games,
    HomebrewApps,
    Osc,
    Settings,
    About,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum SortBy {
    NameAscending,
    NameDescending,
    SizeAscending,
    SizeDescending,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "lowercase"))
export enum ViewAs {
    Grid,
    Table,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "lowercase"))
export enum ThemePreference {
    System,
    Light,
    Dark,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "lowercase"))
export enum WiiOutputFormat {
    Wbfs,
    Iso,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "lowercase"))
export enum GcOutputFormat {
    Iso,
    Ciso,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "lowercase"))
export enum TxtCodesSource {
    WebArchive,
    GameHacking,
    Rc24,
}


@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(default, rename_all = "snake_case"))
export struct ConfigContents {
    always-split: bool,
    mount-point: string,
    remove-sources-apps: bool,
    remove-sources-games: bool,
    scrub-update-partition: bool,
    sort-by: SortBy,
    view-as: ViewAs,
    wii-ip: string,
    txt-codes-source: TxtCodesSource,
    theme-preference: ThemePreference,
    wii-output-format: WiiOutputFormat,
    gc-output-format: GcOutputFormat,
    known-drives: [string],
    show-wii: bool,
    show-gc: bool,
}

export struct Config {
    path: string,
    contents: ConfigContents,
}

export struct DiscInfo {
    err: string,
    path: string,
    format: string,
    game-id: string,
    game-title: string,
    region: string,
    is-wii: bool,
    is-gc: bool,
    disc-number: int,
    disc-version: int,
    is-worth-scrubbing: bool,
}

export struct Game {
    path: string,
    is-wii: bool,
    size-gib: float,
    title: string,
    id: string,
    cover: image,
    search-term: string,
    disc-info: DiscInfo,
    crc32: string,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default, rename_all = "snake_case"))
export struct HomebrewAppMeta {
    name: string,
    coder: string,
    version: string,
    release-date: string,
    short-description: string,
    long-description: string,
}

export struct HomebrewApp {
    path: string,
    slug: string,
    size-mib: float,
    meta: HomebrewAppMeta,
    icon: image,
    search-term: string,
}

export enum ConversionKind {
    Standard,
    Archive,
    Scrub,
}

export struct QueuedStandardConversion {
    in-path: string,
    is-wii: bool,
    game-title: string,
    game-id: string,
    disc-number: int,
}

export struct QueuedArchiveConversion {
    game-title: string,
    in-path: string,
    out-path: string,
}

export struct QueuedScrubConversion {
    game: Game,
}

export struct QueuedConversion {
    kind: ConversionKind,
    standard: QueuedStandardConversion,
    archive: QueuedArchiveConversion,
    scrub: QueuedScrubConversion,
}

export struct DriveInfo {
    label: string,
    used-gib: float,
    games-gib: float,
    apps-mib: float,
    total-gib: float,
    fs-kind: string,
}

export struct Notification {
    text: string,
    critical: bool,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default))
export struct OscAppMetaAsset {
    url: string,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default))
export struct OscAppMetaAssets {
    icon: OscAppMetaAsset,
    archive: OscAppMetaAsset,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default))
export struct OscAppMetaDescription {
    short: string,
    long: string,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default))
export struct OscAppMeta {
    slug: string,
    name: string,
    author: string,
    version: string,
    assets: OscAppMetaAssets,
    uncompressed-size: int,
    release-date: duration, // rust i64
    description: OscAppMetaDescription,
}

export struct OscApp {
    meta: OscAppMeta,
    search-term: string,
    release-date: string,
    icon: image,
}

export struct InstallHomebrewAppsResult {
    app-count: int,
    err: string,
}
