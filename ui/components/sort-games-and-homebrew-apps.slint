import { Card } from "card.slint";
import { IconDisplay, IconSet } from "@lucide";
import { TooltipArea } from "tooltip-area.slint";
import { State } from "../state.slint";
import { MyPalette } from "../styling.slint";
import { VerticalLine } from "vertical-line.slint";
import { SortBy } from "../types.slint";

export component SortGamesAndHomebrewApps inherits Card {
    pure function get-bg(sort-by: SortBy, hovered: bool) -> color {
        if State.config.contents.sort-by == sort-by {
            MyPalette.selection-background
        } else if hovered {
            MyPalette.background
        } else {
            transparent
        }
    }

    height: 38px;
    clip: true;
    border-radius: 10px;

    HorizontalLayout {
        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Sort by name (A→Z)";
            background: get-bg(SortBy.NameAscending, self.has-hover);
            clicked => {
                State.config.contents.sort-by = SortBy.NameAscending;
                State.apply-sorting();
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.ArrowDownAZ;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Sort by name (Z→A)";
            background: get-bg(SortBy.NameDescending, self.has-hover);
            clicked => {
                State.config.contents.sort-by = SortBy.NameDescending;
                State.apply-sorting();
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.ArrowUpAZ;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        VerticalLine { }

        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Sort by size (small→large)";
            background: get-bg(SortBy.SizeAscending, self.has-hover);
            clicked => {
                State.config.contents.sort-by = SortBy.SizeAscending;
                State.apply-sorting();
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.ArrowDown01;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Sort by size (large→small)";
            background: get-bg(SortBy.SizeDescending, self.has-hover);
            clicked => {
                State.config.contents.sort-by = SortBy.SizeDescending;
                State.apply-sorting();
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.ArrowUp01;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }
    }
}
