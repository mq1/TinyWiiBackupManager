import {
    ViewAs,
    SortBy,
    QueuedConversion,
    WiiOutputFormat,
    GcOutputFormat,
} from "types.slint";

export global Rust {
    callback load-games(string);
    callback filter-games(string);
    callback filter-homebrew-apps(string);
    callback filter-osc-apps(string);
    callback load-homebrew-apps(string);
    callback load-osc-apps(bool) -> { h: int, min: int};
    callback set-show-wii(bool);
    callback set-show-gc(bool);
    callback pick-mount-point() -> string;
    callback delete-dir(string);
    callback set-view-as(ViewAs);
    callback set-sort-by(SortBy);
    callback set-wii-output-format(WiiOutputFormat);
    callback set-gc-output-format(GcOutputFormat);
    callback add-conversions-to-queue([QueuedConversion]);
}
