import { MyPalette } from "../styling.slint";

export component MyLineEdit inherits Rectangle {
    out property <string> text;
    in property <string> placeholder-text;

    callback edited();

    height: t.preferred-height;

    Text {
        x: 0;
        y: 0;
        horizontal-alignment: left;
        visible: t.text.is-empty;
        text: placeholder-text;
        color: MyPalette.foreground.transparentize(0.5);
    }

    t := TextInput {
        x: 0;
        y: 0;
        text <=> text;
        edited() => edited();
    }
}
