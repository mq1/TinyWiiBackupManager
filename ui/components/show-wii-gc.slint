import { Card } from "card.slint";
import { CheckBox } from "std-widgets.slint";
import { TooltipArea } from "tooltip-area.slint";
import { IconDisplay, IconSet } from "@lucide";
import { State } from "../state.slint";
import { MyPalette } from "../styling.slint";
import { VerticalLine } from "vertical-line.slint";

export component ShowWiiGc inherits Card {
    pure function get-bg(checked: bool, hovered: bool) -> color {
        if checked {
            MyPalette.selection-background
        } else if hovered {
            MyPalette.background
        } else {
            transparent
        }
    }

    height: 38px;
    clip: true;
    border-radius: 10px;

    HorizontalLayout {
        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Show Wii";
            background: get-bg(State.config.contents.show-wii, self.has-hover);
            clicked => {
                State.config.contents.show-wii = !State.config.contents.show-wii;
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.Pointer;
                size: 14px;
                stroke: MyPalette.foreground;
            }

            if State.config.contents.show-wii: IconDisplay {
                x: 6px;
                y: 24px;
                icon: IconSet.Check;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }

        VerticalLine { }

        TooltipArea {
            width: 24px;
            height: 38px;

            tooltip: "Show GameCube";
            background: get-bg(State.config.contents.show-gc, self.has-hover);
            clicked => {
                State.config.contents.show-gc = !State.config.contents.show-gc;
                State.write-config();
            }

            IconDisplay {
                icon: IconSet.Box;
                size: 14px;
                stroke: MyPalette.foreground;
            }

            if State.config.contents.show-gc: IconDisplay {
                x: 6px;
                y: 24px;
                icon: IconSet.Check;
                size: 14px;
                stroke: MyPalette.foreground;
            }
        }
    }
}
