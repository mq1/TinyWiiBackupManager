import {
    VerticalBox,
    ScrollView,
    HorizontalBox,
    CheckBox,
} from "std-widgets.slint";
import { State } from "state.slint";
import { MyPalette } from "styling.slint";
import { GameCard } from "components/game-card.slint";
import { GameFilter } from "components/game-filter.slint";
import { IconSet, IconDisplay } from "@lucide";
import { Card } from "components/card.slint";
import { VerticalLine } from "components/vertical-line.slint";
import { TooltipArea } from "components/tooltip-area.slint";

export component GameGridPage inherits VerticalLayout {
    alignment: start;

    HorizontalBox {
        alignment: space-between;

        GameFilter { }

        HorizontalLayout {
            Card {
                HorizontalBox {
                    CheckBox {
                        checked: State.show-wii;
                    }

                    TooltipArea {
                        tooltip: "Show Wii";
                        width: 14px;

                        IconDisplay {
                            icon: IconSet.Pointer;
                            size: 14px;
                        }
                    }

                    VerticalLine { }

                    CheckBox {
                        checked: State.show-gc;
                    }

                    TooltipArea {
                        tooltip: "Show GameCube";
                        width: 14px;

                        IconDisplay {
                            icon: IconSet.Box;
                            size: 14px;
                        }
                    }
                }
            }
        }
    }

    ScrollView {
        height: parent.height - 40px;
        viewport-height: v.preferred-height;

        v := VerticalLayout {
            padding: 5px;

            if State.game-filter.is-empty: HorizontalLayout {
                padding-left: 5px;
                padding-bottom: 5px;

                IconDisplay {
                    icon: IconSet.Pointer;
                    size: 18px;
                    stroke: MyPalette.foreground;
                }

                Text {
                    text: " Wii games";
                    font-size: 18px;
                }
            }

            if State.game-filter.is-empty: FlexBoxLayout {
                for game[i] in State.game-list.games: HorizontalLayout {
                    padding: game.is-wii ? 5px : 0px;

                    if game.is-wii: GameCard {
                        game: game;
                    }
                }
            }

            if State.game-filter.is-empty: HorizontalLayout {
                padding-left: 5px;
                padding-top: 20px;
                padding-bottom: 5px;

                IconDisplay {
                    icon: IconSet.Box;
                    size: 18px;
                    stroke: MyPalette.foreground;
                }

                Text {
                    text: " GameCube games";
                    font-size: 18px;
                }
            }

            if State.game-filter.is-empty: FlexBoxLayout {
                for game[i] in State.game-list.games: HorizontalLayout {
                    padding: game.is-wii ? 0px : 5px;

                    if !game.is-wii: GameCard {
                        game: game;
                    }
                }
            }

            if !State.game-filter.is-empty: FlexBoxLayout {
                for game[i] in State.filtered-games: HorizontalLayout {
                    padding: 5px;

                    GameCard {
                        game: game;
                    }
                }
            }
        }
    }
}
