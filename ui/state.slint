import {
    Page,
    Config,
    Message,
    IconButtonKind,
    GameList,
    MessageKind,
    Game,
} from "types.slint";
import { Rust } from "rust.slint";
import { Palette } from "std-widgets.slint";

export global State {
    in property <string> version;
    in-out property <Page> current-page;
    in-out property <Game> current-game;
    in property <string> data-dir;
    in-out property <Config> config;
    in-out property <Message> message;
    in-out property <{a-used: float, b-total: float}> drive-usage;
    in-out property <GameList> game-list;
    in-out property <[Game]> filtered-games;
    in-out property <string> game-filter;
    in property <string> status;
    in property <{a-text: string, b-mouse-x: length, c-mouse-y: length}> tooltip;

    // ↑ Model
    // ---------
    // ↓ Update

    public function info(info: string) {
        if !info.is-empty {
            message.text = info;
            message.kind = MessageKind.Info;
            message.data = "";
        }
    }

    public function err(err: string) {
        if !err.is-empty {
            message.text = err;
            message.kind = MessageKind.Error;
            message.data = "";
        }
    }

    public function dismiss() {
        message.text = "";
    }

    public function write-config() {
        let res = Rust.write-config(config);
        err(res.err);
    }

    public function pick-mount-point() {
        let mount-point = Rust.pick-mount-point();
        if !mount-point.is-empty {
            config.contents.mount-point = mount-point;
            write-config();
            drive-usage = Rust.get-drive-usage(mount-point);
            game-list = Rust.get-game-list(mount-point);
        }
    }

    public function delete-dir(path: string) {
        dismiss();
        let res = Rust.delete-dir(path);
        err(res.err);
        drive-usage = Rust.get-drive-usage(config.contents.mount-point);
        game-list = Rust.get-game-list(config.contents.mount-point);
    }

    public function filter-games() {
        if game-filter.is-empty {
            filtered-games = [];
        } else {
            filtered-games = Rust.filter-games(game-list.games, game-filter);
        }
    }
}
