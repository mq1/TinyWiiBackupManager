import { Palette } from "std-widgets.slint";

export global MyPalette {
    pure function is-dark() -> bool {
        Palette.color-scheme == ColorScheme.dark
    }

    // this is the macos window color
    out property <brush> card-background: Palette.color-scheme == ColorScheme.light ? #ffffff : #1e1e1e;

    // inspired by shadcn/ui b0
    out property <brush> background: is-dark() ? oklch(0.269, 0, 0) : oklch(0.97, 0, 0);
    out property <brush> foreground: is-dark() ? oklch(0.985, 0, 0) : oklch(0.145, 0, 0);
    out property <brush> border: is-dark() ? oklch(1, 0, 0, 10%) : oklch(0.922, 0, 0);
    out property <brush> selection-background: Palette.accent-background.transparentize(0.6);
    out property <brush> accent-background: Palette.accent-background;
    out property <brush> accent-foreground: is-dark() ? oklch(0.145, 0, 0) : oklch(0.985, 0, 0);
    out property <brush> overlay: background.darker(0.5).transparentize(0.5);
    out property <brush> destructive: is-dark() ? oklch(0.704, 0.191, 22.216) : oklch(0.577, 0.245, 27.325);
}
