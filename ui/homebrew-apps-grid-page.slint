import { ScrollView } from "std-widgets.slint";
import { State } from "state.slint";
import { MyPalette } from "styling.slint";
import { IconSet, IconDisplay } from "@lucide";
import { HomebrewAppsToolbar } from "components/homebrew-apps-toolbar.slint";
import { HomebrewAppCard } from "components/homebrew-app-card.slint";
import {
    HomebrewAppsOtherToolbar,
} from "components/homebrew-apps-other-toolbar.slint";

export component HomebrewAppsGridPage inherits Rectangle {
    toolbar := HomebrewAppsToolbar {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
    }

    ScrollView {
        x: 0px;
        y: toolbar.height + 10px;
        height: parent.height - toolbar.height - 10px;
        width: parent.width;

        VerticalLayout {
            padding: 10px;
            spacing: 10px;

            HomebrewAppsOtherToolbar { }

            if State.homebrew-app-list.filter.is-empty: FlexboxLayout {
                spacing: 10px;

                for app in State.homebrew-app-list.apps: HomebrewAppCard {
                    app: app;
                }
            }

            if !State.homebrew-app-list.filter.is-empty: FlexboxLayout {
                spacing: 10px;

                for app in State.homebrew-app-list.filtered-apps: HomebrewAppCard {
                    app: app;
                }
            }
        }
    }
}
