import { ScrollView } from "std-widgets.slint";
import { MyPalette } from "styling.slint";
import { IconSet, IconDisplay } from "@lucide";
import { HomebrewAppsToolbar } from "components/homebrew-apps-toolbar.slint";
import { HomebrewAppCard } from "components/homebrew-app-card.slint";
import {
    HomebrewAppsOtherToolbar,
} from "components/homebrew-apps-other-toolbar.slint";
import { HomebrewApp, Config } from "types.slint";

export component HomebrewAppsGridPage inherits VerticalLayout {
    in property <[HomebrewApp]> apps;
    in property <Config> config;

    callback open-info(int);

    private property <int> col-count: max(1, floor((self.width - 10px) / (172px + 10px)));

    HorizontalLayout {
        padding: 10px;

        HomebrewAppsToolbar {
            config: config;
        }
    }

    ScrollView {
        width: parent.width;
        viewport-height: v.preferred-height;

        v := VerticalLayout {
            padding: 10px;
            padding-top: 0px;
            spacing: 10px;

            HomebrewAppsOtherToolbar {
                apps: apps;
            }

            GridLayout {
                spacing: 10px;

                for app[i] in apps: HomebrewAppCard {
                    row: i / col-count;
                    col: mod(i, col-count);

                    app: app;
                    open-info() => open-info(i);
                }
            }
        }
    }
}
