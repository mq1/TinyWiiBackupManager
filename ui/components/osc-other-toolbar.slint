import { MyPalette } from "../styling.slint";
import { State } from "../state.slint";
import { OscFilter } from "osc-filter.slint";

export component OscOtherToolbar inherits HorizontalLayout {
    alignment: space-between;
    height: 38px;
    padding-right: 10px;

    OscFilter { }

    Text {
        height: parent.height;
        vertical-alignment: center;
        horizontal-alignment: end;
        text: "refreshed \{State.last-osc-refresh}";
    }
}
