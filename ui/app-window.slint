import { Palette } from "std-widgets.slint";
import { Navbar } from "components/navbar.slint";
import { GameGridPage } from "game-grid-page.slint";
import { SettingsPage } from "settings-page.slint";
import { AboutPage } from "about-page.slint";
import {
    Page,
    ViewAs,
    Game,
    HomebrewApp,
    OscApp,
    Notification,
    Config,
    QueuedConversion,
    DriveInfo,
    ThemePreference,
} from "types.slint";
import { MyPalette } from "styling.slint";
import { Rust } from "rust.slint";
import { VerticalLine } from "components/vertical-line.slint";
import { Card } from "components/card.slint";
import { GameTablePage } from "game-table-page.slint";
import { Notifications } from "components/notifications.slint";
import { GameInfoModal } from "components/game-info-modal.slint";
import { HomebrewAppsGridPage } from "homebrew-apps-grid-page.slint";
import { HomebrewAppInfoModal } from "components/homebrew-app-info-modal.slint";
import { HomebrewAppsTablePage } from "homebrew-apps-table-page.slint";
import { OscGridPage } from "osc-grid-page.slint";
import { OscTablePage } from "osc-table-page.slint";
import { OscAppInfoModal } from "components/osc-app-info-modal.slint";
import { ConfirmationModal } from "components/confirmation-modal.slint";
import { Tooltip } from "tooltip.slint";

export * from "types.slint";
export { Rust }

export component AppWindow inherits Window {
    pure function get-window-title() -> string {
        if drive-info.length == 0 {
            "TinyWiiBackupManager  ›  No drive selected"
        } else {
            "TinyWiiBackupManager  ›  \{drive-info[0].label}  (\{drive-info[0].used-gib.to-fixed(2)}/\{drive-info[0].total-gib.to-fixed(2)} GiB)"
        }
    }

    min-width: 800px;
    min-height: 600px;
    background: MyPalette.background;
    title: get-window-title();
    default-font-size: 14px;

    private property <Page> current-page: Page.Games;
    private property <int> current-game-i: -1;
    private property <int> current-homebrew-app-i: -1;
    private property <int> current-osc-app-i: -1;
    private property <int> game-to-scrub: -1;
    private property <int> game-to-delete: -1;
    private property <int> homebrew-app-to-delete: -1;

    in property <Config> config;
    in property <string> app-version;
    in property <string> data-dir;
    in property <string> status;
    in property <string> crc32-status;
    in property <[Game]> games;
    in property <[HomebrewApp]> homebrew-apps;
    in property <[OscApp]> osc-apps;
    in property <[Notification]> notifications;
    in property <[DriveInfo]> drive-info;
    in property <[QueuedConversion]> conversion-queue;
    in property <[QueuedConversion]> conversion-queue-buffer;

    // Initialize
    Timer {
        interval: 1ms;
        running: true;
        triggered => {
            if config.contents.theme-preference == ThemePreference.Light {
                Palette.color-scheme = ColorScheme.light;
            } else if config.contents.theme-preference == ThemePreference.Dark {
                Palette.color-scheme = ColorScheme.dark;
            }
            Rust.set-window-color(Palette.color-scheme == ColorScheme.dark);
            Rust.refresh-all();
            self.running = false;
        }
    }

    HorizontalLayout {
        Navbar {
            current-page <=> current-page;
        }

        VerticalLayout {
            Rectangle {
                background: MyPalette.alternate-background;
                border-top-left-radius: 10px;
                border-width: 1px;
                border-color: MyPalette.border;

                if current-page == Page.Games && config.contents.view-as == ViewAs.Grid: GameGridPage {
                    games: games;
                    config: config;
                    open-info(i) => {
                        current-game-i = i;
                    }
                }
                if current-page == Page.Games && config.contents.view-as == ViewAs.Table: GameTablePage {
                    games: games;
                    config: config;
                    open-info(i) => {
                        current-game-i = i;
                    }
                }
                if current-page == Page.HomebrewApps && config.contents.view-as == ViewAs.Grid: HomebrewAppsGridPage {
                    apps: homebrew-apps;
                    config: config;
                    open-info(i) => {
                        current-homebrew-app-i = i;
                    }
                }
                if current-page == Page.HomebrewApps && config.contents.view-as == ViewAs.Table: HomebrewAppsTablePage {
                    apps: homebrew-apps;
                    config: config;
                    open-info(i) => {
                        current-homebrew-app-i = i;
                    }
                }
                if current-page == Page.Osc && config.contents.view-as == ViewAs.Grid: OscGridPage {
                    apps: osc-apps;
                    config: config;
                    open-info(i) => {
                        current-osc-app-i = i;
                    }
                }
                if current-page == Page.Osc && config.contents.view-as == ViewAs.Table: OscTablePage {
                    apps: osc-apps;
                    config: config;
                    open-info(i) => {
                        current-osc-app-i = i;
                    }
                }
                if current-page == Page.Settings: SettingsPage {
                    config: config;
                }
                if current-page == Page.About: AboutPage {
                    app-version: app-version;
                    data-dir: data-dir;
                }
            }

            if !status.is-empty: HorizontalLayout {
                VerticalLine { }

                HorizontalLayout {
                    padding: 10px;

                    Text {
                        text: status;
                    }
                }
            }
        }
    }

    if game-to-delete >= 0: ConfirmationModal {
        message: "Are you sure you want to delete \{games[game-to-delete].title}? This action cannot be undone.";

        cancelled => {
            game-to-delete = -1;
        }
        confirmed => {
            Rust.delete-game(games[game-to-delete]);
            game-to-delete = -1;
        }
    }

    if homebrew-app-to-delete >= 0: ConfirmationModal {
        message: "Are you sure you want to delete \{homebrew-apps[homebrew-app-to-delete].meta.name}? This action cannot be undone.";

        cancelled => {
            homebrew-app-to-delete = -1;
        }
        confirmed => {
            Rust.delete-homebrew-app(homebrew-apps[homebrew-app-to-delete]);
            homebrew-app-to-delete = -1;
        }
    }

    if game-to-scrub >= 0: ConfirmationModal {
        message: "Are you sure you want to scrub \{games[game-to-scrub].title}? This action cannot be undone.";

        cancelled => {
            game-to-scrub = -1;
        }
        confirmed => {
            Rust.scrub-game(games[game-to-scrub]);
            game-to-scrub = -1;
        }
    }

    if conversion-queue-buffer.length > 0: ConfirmationModal {
        message: "Are you sure you want to add \{conversion-queue-buffer.length} conversions to the queue?";

        cancelled => Rust.cancel-conversions();
        confirmed => Rust.confirm-conversions();
    }

    if current-game-i >= 0: GameInfoModal {
        game: games[current-game-i];
        closed => {
            current-game-i = -1;
            Rust.clear-crc32-status();
        }
    }

    if current-homebrew-app-i >= 0: HomebrewAppInfoModal {
        app: homebrew-apps[current-homebrew-app-i];
        closed => {
            current-homebrew-app-i = -1;
        }
    }

    if current-osc-app-i >= 0: OscAppInfoModal {
        app: osc-apps[current-osc-app-i];
        closed => {
            current-osc-app-i = -1;
        }
    }

    if notifications.length > 0: Notifications {
        x: root.width - self.width;
        y: root.height - self.height;

        notifications: notifications;
    }

    if !Tooltip.text.is-empty: Card {
        x: Tooltip.mouse-x + t.preferred-width + 18px > root.width ? Tooltip.mouse-x - t.preferred-width - 18px : Tooltip.mouse-x;
        y: Tooltip.mouse-y;

        width: t.preferred-width + 18px;
        height: t.preferred-height + 16px;

        HorizontalLayout {
            padding-top: 8px;
            padding-bottom: 8px;
            padding-left: 9px;
            padding-right: 9px;

            t := Text {
                text: Tooltip.text;
            }
        }
    }
}
