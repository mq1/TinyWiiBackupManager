export enum Page {
    Games,
    HomebrewApps,
    Settings,
    About,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(rename_all = "snake_case"))
export enum SortBy {
    NameAscending,
    NameDescending,
    SizeAscending,
    SizeDescending,
}

@rust-attr(derive(serde::Serialize, serde::Deserialize))
@rust-attr(serde(default, rename_all = "snake_case"))
export struct ConfigContents {
    always-split: bool,
    mount-point: string,
    remove-sources-apps: bool,
    remove-sources-games: bool,
    scrub-update-partition: bool,
    sort-by: SortBy,
    view-as-table: bool,
    wii-ip: string,
    txt-codes-source: string,
    theme-preference: string,
    wii-output-format: string,
    gc-output-format: string,
    show-wii: bool,
    show-gc: bool,
    known-drives: [string],
}

export struct Config {
    path: string,
    contents: ConfigContents,
}

export enum IconButtonKind {
    Primary,
    Secondary,
    Destructive,
}

export struct Game {
    path: string,
    is-wii: bool,
    size-gib: float,
    title: string,
    id: string,
    cover: image,
}

export struct GameList {
    games: [Game],
    filter: string,
    filtered-games: [Game],
    total-size: float,
}

@rust-attr(derive(serde::Deserialize))
@rust-attr(serde(default, rename_all = "snake_case"))
export struct HomebrewAppMeta {
    name: string,
    coder: string,
    version: string,
    release-date: string,
    short-description: string,
    long-description: string,
}

export struct HomebrewApp {
    path: string,
    slug: string,
    size-mib: float,
    meta: HomebrewAppMeta,
    icon: image,
}

export struct HomebrewAppList {
    apps: [HomebrewApp],
    filter: string,
    filtered-apps: [HomebrewApp],
    total-size: float,
}

export struct DiscInfo {
    err: string,
    path: string,
    format: string,
    game-id: string,
    game-title: string,
    region: string,
    is-wii: bool,
    is-gc: bool,
    disc-number: int,
    disc-version: int,
    crc32: string,
    is-worth-scrubbing: bool,
}

export struct EmptyResult {
    err: string,
}

export struct QueuedConversion {
    in-path: string,
    out-path: string,
    flags: int,
    game-title: string,
    game-id: string,
    disc-number: int,
}

export struct DriveInfo {
    label: string,
    used-gib: float,
    total-gib: float,
    fs-kind: string,
}

export struct Notification {
    text: string,
    critical: bool,
}
