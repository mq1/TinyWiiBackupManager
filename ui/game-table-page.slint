import { GamesToolbar } from "components/games-toolbar.slint";
import { ScrollView } from "std-widgets.slint";
import { State } from "state.slint";
import { HorizontalLine } from "components/horizontal-line.slint";
import { IconButton } from "components/icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { Card } from "components/card.slint";
import { MyPalette } from "styling.slint";
import { VerticalLine } from "components/vertical-line.slint";

export component GameTablePage inherits Rectangle {
    toolbar := GamesToolbar {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
    }

    Card {
        x: 10px;
        y: toolbar.height + 20px;
        height: parent.height - toolbar.height - 30px;
        width: parent.width - 20px;
        clip: true;

        ScrollView {
            x: 0px;
            y: 0px;
            height: parent.height;
            viewport-height: v.preferred-height;

            v := VerticalLayout {
                for game in State.game-list.games: VerticalLayout {
                    spacing: 5px;

                    if (game.is-wii && State.config.contents.show-wii) || (!game.is-wii && State.config.contents.show-gc): VerticalLayout {
                        HorizontalLayout {
                            alignment: space-between;
                            padding-left: 5px;

                            HorizontalLayout {
                                spacing: 5px;

                                VerticalLayout {
                                    alignment: center;

                                    IconDisplay {
                                        icon: game.is-wii ? IconSet.Pointer : IconSet.Box;
                                        size: 14px;
                                        stroke: MyPalette.foreground;
                                    }
                                }

                                Text {
                                    height: 24px;
                                    vertical-alignment: center;
                                    text: "\{game.title} [\{game.id}]";
                                    overflow: elide;
                                }
                            }

                            HorizontalLayout {
                                Text {
                                    height: 24px;
                                    vertical-alignment: center;
                                    text: "\{game.size-gib} GiB  ";
                                }

                                VerticalLine { }

                                IconButton {
                                    tooltip: "Game info";
                                    icon: IconSet.Info;
                                    height: 24px;
                                    width: 24px;
                                    squared: true;
                                    clicked => {
                                        State.open-game-info(game);
                                    }
                                }

                                VerticalLine { }

                                IconButton {
                                    icon: IconSet.HardDriveDownload;
                                    tooltip: "Archive to PC";
                                    height: 24px;
                                    width: 24px;
                                    squared: true;
                                    clicked => {
                                        State.archive-game(game);
                                    }
                                }

                                VerticalLine { }

                                IconButton {
                                    icon: IconSet.Trash;
                                    tooltip: "Delete game";
                                    height: 24px;
                                    width: 24px;
                                    squared: true;
                                    clicked => {
                                        State.deleting-dir = game.path;
                                    }
                                }
                            }
                        }

                        HorizontalLine {
                            background: MyPalette.foreground.transparentize(0.5);
                        }
                    }
                }
            }
        }
    }
}
