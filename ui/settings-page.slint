import { ScrollView, Palette } from "std-widgets.slint";
import { IconSet, IconDisplay } from "@lucide";
import { SettingCard } from "components/setting-card.slint";
import { MyPalette } from "styling.slint";
import {
    WiiOutputFormat,
    GcOutputFormat,
    TxtCodesSource,
    ThemePreference,
    Config,
} from "types.slint";
import { Rust } from "rust.slint";

export component SettingsPage inherits Rectangle {
    in property <Config> config;

    HorizontalLayout {
        x: 10px;
        y: 20px;
        spacing: 5px;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Settings";
            font-size: 18px;
        }
    }

    ScrollView {
        x: 0px;
        y: 38px + 20px;
        height: root.height - 38px - 20px;

        VerticalLayout {
            width: 100%;
            padding-left: 10px;
            padding-right: 15px;
            padding-bottom: 10px;
            spacing: 10px;

            SettingCard {
                icon: IconSet.Disc3;
                label: "Wii output format";
                items: ["WBFS (recommended)", "ISO (very large)"];
                active-item: config.contents.wii-output-format == WiiOutputFormat.Wbfs ? 0 : 1;

                selected(i) => {
                    if i == 0 {
                        Rust.set-wii-output-format(WiiOutputFormat.Wbfs);
                    } else {
                        Rust.set-wii-output-format(WiiOutputFormat.Iso);
                    }
                }
            }

            SettingCard {
                icon: IconSet.Disc3;
                label: "GameCube output format";
                items: [
                    "ISO (recommended)",
                    "CISO (much smaller, slightly slower, less metadata in game loaders)"
                ];
                active-item: config.contents.gc-output-format == GcOutputFormat.Iso ? 0 : 1;

                selected(i) => {
                    if i == 0 {
                        Rust.set-gc-output-format(GcOutputFormat.Iso);
                    } else {
                        Rust.set-gc-output-format(GcOutputFormat.Ciso);
                    }
                }
            }

            SettingCard {
                icon: IconSet.SquareSplitHorizontal;
                label: "Split output";
                items: ["Only when needed (recommended)", "Always 4GB-32KB"];
                active-item: config.contents.always-split ? 1 : 0;

                selected(i) => {
                    Rust.set-always-split(i == 1);
                }
            }

            SettingCard {
                icon: IconSet.FileMinusCorner;
                label: "Remove update partition on WBFS/CISO";
                items: [
                    "No (recommended)",
                    "Yes (saves some space; update partition is zeroed, but still there)"
                ];
                active-item: config.contents.scrub-update-partition ? 1 : 0;

                selected(i) => {
                    Rust.set-scrub-update-partition(i == 1);
                }
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding games";
                items: ["No (recommended)", "Yes"];
                active-item: config.contents.remove-sources-games ? 1 : 0;

                selected(i) => {
                    Rust.set-remove-sources-games(i == 1);
                }
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding apps";
                items: ["No (recommended)", "Yes"];
                active-item: config.contents.remove-sources-apps ? 1 : 0;
            }

            SettingCard {
                pure function get-active-item() -> int {
                    if config.contents.txt-codes-source == TxtCodesSource.WebArchive {
                        0
                    } else if config.contents.txt-codes-source == TxtCodesSource.GameHacking {
                        1
                    } else {
                        2
                    }
                }

                icon: IconSet.Skull;
                label: "Cheat codes source";
                items: [
                    "geckocodes.org-201909 archive (recommended)",
                    "gamehacking.org (up to date)",
                    "codes.rc24.xyz",
                ];
                active-item: get-active-item();

                selected(i) => {
                    if i == 0 {
                        Rust.set-txt-codes-source(TxtCodesSource.WebArchive);
                    } else if i == 1 {
                        Rust.set-txt-codes-source(TxtCodesSource.GameHacking);
                    } else {
                        Rust.set-txt-codes-source(TxtCodesSource.Rc24);
                    }
                }
            }

            SettingCard {
                pure function get-active-item() -> int {
                    if config.contents.theme-preference == ThemePreference.System {
                        0
                    } else if config.contents.theme-preference == ThemePreference.Light {
                        1
                    } else {
                        2
                    }
                }

                icon: IconSet.SunMoon;
                label: "Theme";
                items: ["System (requires restart)", "Light", "Dark"];
                active-item: get-active-item();

                selected(i) => {
                    if i == 0 {
                        Rust.set-theme-preference(ThemePreference.System);
                    } else if i == 1 {
                        Rust.set-theme-preference(ThemePreference.Light);
                        Palette.color-scheme = ColorScheme.light;
                        Rust.set-window-color(false);
                    } else {
                        Rust.set-theme-preference(ThemePreference.Dark);
                        Palette.color-scheme = ColorScheme.dark;
                        Rust.set-window-color(true);
                    }
                }
            }
        }
    }
}
