import { Card } from "card.slint";
import { HomebrewApp } from "../types.slint";
import { IconButton } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { Logic } from "../logic.slint";
import { TooltipArea } from "tooltip-area.slint";

export component HomebrewAppCard inherits Card {
    in property <HomebrewApp> app;
    callback open-info();

    private property <string> update: app.osc-i == -1 || Logic.osc-apps[app.osc-i].meta.version == app.meta.version ? "" : Logic.osc-apps[app.osc-i].meta.version;

    width: 172px;
    height: self.min-height;

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        HorizontalLayout {
            alignment: space-between;

            HorizontalLayout {
                spacing: 5px;

                IconDisplay {
                    icon: IconSet.Tag;
                    size: 13px;
                    stroke: MyPalette.foreground;
                }

                Text {
                    text: app.meta.version;
                    wrap: no-wrap;
                    overflow: elide;
                }

                if !update.is-empty: TooltipArea {
                    width: 13px;
                    height: 13px;
                    tooltip: "Update available: \{update}";

                    IconDisplay {
                        icon: IconSet.ArrowUp;
                        size: 13px;
                        stroke: MyPalette.foreground;
                    }
                }
            }

            Text {
                text: "\{app.size-mib.to-fixed(2)} MiB";
                wrap: no-wrap;
                horizontal-alignment: right;
            }
        }

        Image {
            source: app.icon;
            height: 48px;
        }

        Text {
            text: app.meta.name;
            horizontal-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        HorizontalLayout {
            spacing: 5px;

            IconButton {
                label: "Info";
                icon: IconSet.Info;
                clicked => open-info();
            }

            if !update.is-empty: IconButton {
                icon: IconSet.ArrowUp;
                tooltip: "Update app to \{update}";
                clicked => Logic.install-osc-app(Logic.osc-apps[app.osc-i]);
            }

            IconButton {
                icon: IconSet.Trash;
                tooltip: "Delete app";
                clicked => Logic.delete-homebrew-app(app);
            }
        }
    }
}
